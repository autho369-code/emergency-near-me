{
  "version": 2,
  "buildCommand": "echo 'Static site — no build needed'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/dashboard/", "destination": "/dashboard.html" },
    { "source": "/agents", "destination": "/agent_dashboard.html" },
    { "source": "/agents/", "destination": "/agent_dashboard.html" },
    { "source": "/provider", "destination": "/provider.html" },
    { "source": "/provider/", "destination": "/provider.html" },
    { "source": "/pricing", "destination": "/provider.html" },
    { "source": "/pricing/", "destination": "/provider.html" },
    { "source": "/IL/:city/:service/", "destination": "/IL/:city/:service/index.html" },
    { "source": "/:state/:city/:service/", "destination": "/:state/:city/:service/index.html" }
  ]
}
